project_name = "uptime-kuma"
environment  = "shared"
aws_region   = "us-east-1"
owner        = "ofek"

# Must be globally unique across all AWS accounts.
# Example:
# uptime-kuma-terraform-state-ofek-20260608
state_bucket_name = "uptime-kuma-terraform-state-ofek-CHANGE-ME"

noncurrent_version_expiration_days = 90

alertmanager_email = "your-email@example.com"